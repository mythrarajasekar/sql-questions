-- Display All Records
SELECT * FROM Sales;

-- Total Monthly Sales for Each Year
SELECT YEAR(SaleDate) AS Year,
MONTH(SaleDate) AS Month,
SUM(Amount) AS TotalSales
FROM Sales
GROUP BY YEAR(SaleDate), MONTH(SaleDate)
ORDER BY Year, Month;
