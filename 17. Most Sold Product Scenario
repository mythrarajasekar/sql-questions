-- Display Records
SELECT * FROM Product;
SELECT * FROM Sales;

-- Most Sold Product
SELECT p.ProductID, p.ProductName, SUM(s.Quantity) AS TotalSold
FROM Product p
JOIN Sales s
ON p.ProductID = s.ProductID
GROUP BY p.ProductID, p.ProductName
ORDER BY TotalSold DESC
LIMIT 1;
