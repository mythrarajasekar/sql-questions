-- Display Records
SELECT * FROM Customer;
SELECT * FROM Orders;

-- Latest Order of Every Customer
SELECT *
FROM (
    SELECT o.*,
    ROW_NUMBER() OVER(PARTITION BY CustomerID ORDER BY OrderDate DESC) AS rn
    FROM Orders o
) t
WHERE rn = 1;
