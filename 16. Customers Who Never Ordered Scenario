-- Display Records
SELECT * FROM Customer;
SELECT * FROM Orders;

-- Customers Who Never Ordered (LEFT JOIN)
SELECT c.*
FROM Customer c
LEFT JOIN Orders o
ON c.CustomerID = o.CustomerID
WHERE o.CustomerID IS NULL;

-- OR

-- Customers Who Never Ordered (NOT EXISTS)
SELECT *
FROM Customer c
WHERE NOT EXISTS (
    SELECT *
    FROM Orders o
    WHERE o.CustomerID = c.CustomerID
);
