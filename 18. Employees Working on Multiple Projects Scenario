-- Display Records
SELECT * FROM Employee;
SELECT * FROM Project;

-- Employees Working on More Than One Project
SELECT e.EmpID, e.EmpName, COUNT(p.ProjectID) AS TotalProjects
FROM Employee e
JOIN Project p
ON e.EmpID = p.EmpID
GROUP BY e.EmpID, e.EmpName
HAVING COUNT(p.ProjectID) > 1;
