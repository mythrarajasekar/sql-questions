SELECT e.*
FROM Employee e
LEFT JOIN Project p
ON e.EmpID = p.EmpID
WHERE p.EmpID IS NULL;

SELECT *
FROM Employee e
WHERE NOT EXISTS (
    SELECT *
    FROM Project p
    WHERE p.EmpID = e.EmpID
);
